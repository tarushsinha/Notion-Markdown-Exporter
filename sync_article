#!/usr/bin/env bash

set -u

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VENV_DIR="$SCRIPT_DIR/.venv"
REQUIREMENTS_FILE="$SCRIPT_DIR/requirements.txt"
APP_FILE="$SCRIPT_DIR/sync_notion_article.py"

find_python() {
    if command -v python3 >/dev/null 2>&1; then
        command -v python3
        return 0
    fi

    if command -v python >/dev/null 2>&1; then
        command -v python
        return 0
    fi

    return 1
}

print_python_missing() {
    cat <<'EOF'
Python is not installed or not available on PATH.
Install Python 3, then run ./sync_article again.
EOF
}

print_pip_missing() {
    cat <<'EOF'
pip is not available for this workspace environment.
Install Python with venv/pip support, or enable pip for the selected interpreter, then run ./sync_article again.
EOF
}

SYSTEM_PYTHON="$(find_python || true)"
if [ -z "$SYSTEM_PYTHON" ]; then
    print_python_missing
    exit 1
fi

if [ -x "$VENV_DIR/bin/python" ]; then
    VENV_PYTHON="$VENV_DIR/bin/python"
else
    if ! "$SYSTEM_PYTHON" -m venv "$VENV_DIR" >/dev/null 2>&1; then
        cat <<'EOF'
Unable to create a local virtual environment in this workspace.
Make sure Python 3 includes venv support, then run ./sync_article again.
EOF
        exit 1
    fi
    VENV_PYTHON="$VENV_DIR/bin/python"
fi

if ! "$VENV_PYTHON" -m pip --version >/dev/null 2>&1; then
    print_pip_missing
    exit 1
fi

if ! "$VENV_PYTHON" -m pip install -r "$REQUIREMENTS_FILE"; then
    if ! "$VENV_PYTHON" -m pip --version >/dev/null 2>&1; then
        print_pip_missing
    else
        echo "Failed to install requirements from $REQUIREMENTS_FILE."
    fi
    exit 1
fi

exec "$VENV_PYTHON" "$APP_FILE"
